{
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/demo", "destination": "/billeat_demo.html" },
    { "source": "/", "destination": "/billeat_website.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ]
}
